GODADDY_API_KEY=your_api_key_here
GODADDY_API_SECRET=your_api_secret_here
GODADDY_BASE_URL=https://api.godaddy.com

#
# Multi-profile credentials (alternative to .env):
#
# Create individual files in profiles/<name>.env, e.g.:
#
#   profiles/production.env
#   profiles/ote.env
#
# Each file uses the same GODADDY_API_KEY / GODADDY_API_SECRET / GODADDY_BASE_URL
# format as this file.  The script will show a selection menu at startup
# if more than one profile exists.
#
# See specs/003-multi-profile-credentials/ for full details.
